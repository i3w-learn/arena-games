      { "property": "x", "delta": -40, "duration": 120, "ease": "quad.in" }
    ]
  },
  "opponentAttack": {
    "steps": [
      { "property": "x", "delta": -40, "duration": 150, "ease": "quad.out" },
      { "property": "x", "delta": 40, "duration": 120, "ease": "quad.in" }
    ]
  },
  "takeHit": {
    "steps": [
      { "property": "alpha", "to": 0.3, "duration": 80, "ease": "linear" },
      { "property": "alpha", "to": 1, "duration": 80, "ease": "linear" }
